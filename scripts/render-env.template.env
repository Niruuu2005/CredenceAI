# Copy values into Render → credenceai-api → Environment (never commit real secrets).
# Worker inherits DATABASE_URL and REDIS_URL from credenceai-api via render.yaml.
# Full guide: docs/manual-setup.md

APP_ENV=production
MOCK_SERVICES=false
# Free tier: true (inline jobs). Paid tier with worker: false
CELERY_ALWAYS_EAGER=true
# Skip localhost OpenSearch/MinIO probes on Render (use PostgreSQL search + local storage)
SEARCH_BACKEND=database
STORAGE_BACKEND=local
RATE_LIMIT_ENABLED=true
ENABLE_API_KEY_AUTH=true

# Neon Postgres (rotate if ever exposed in chat/logs)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Upstash Redis (rotate if ever exposed in chat/logs)
REDIS_URL=rediss://default:TOKEN@HOST:6379

# Auto-generated by Render Blueprint — or: openssl rand -hex 32
JWT_SECRET=

# Vercel frontend URLs — JSON array, no trailing slash
CORS_ALLOWED_ORIGINS=["https://credence-ai-gamma.vercel.app","https://credence-ai-patilniraj413-5474s-projects.vercel.app","http://localhost:3000","http://localhost:5173"]

# At least one OAuth provider required in production (canonical frontend: gamma)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://credence-ai-gamma.vercel.app/auth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://credence-ai-gamma.vercel.app/auth/github/callback

# Render free-tier: background self-ping to prevent spin-down (web service only)
SELF_KEEPALIVE_ENABLED=true
SELF_KEEPALIVE_INTERVAL_SEC=30
API_PUBLIC_URL=https://credenceai-api.onrender.com
