# Copy values into Render → credenceai-api → Environment (never commit real secrets).
# Worker inherits DATABASE_URL and REDIS_URL from credenceai-api via render.yaml.

APP_ENV=production
MOCK_SERVICES=false
CELERY_ALWAYS_EAGER=false
RATE_LIMIT_ENABLED=true
ENABLE_API_KEY_AUTH=true

# Neon Postgres (rotate if ever exposed in chat/logs)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Upstash Redis (rotate if ever exposed in chat/logs)
REDIS_URL=rediss://default:TOKEN@HOST:6379

# Auto-generated by Render Blueprint — or: openssl rand -hex 32
JWT_SECRET=

# Vercel frontend URL — JSON array, no trailing slash
CORS_ALLOWED_ORIGINS=["https://your-app.vercel.app"]

# At least one OAuth provider required in production
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-app.vercel.app/auth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://your-app.vercel.app/auth/github/callback
