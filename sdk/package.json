{
  "name": "@credenceai/sdk",
  "version": "0.1.1",
  "description": "TypeScript/JavaScript SDK for the CredenceAI search-intelligence API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" \"examples/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"examples/**/*.ts\""
  },
  "keywords": [
    "credenceai",
    "sdk",
    "search",
    "ai",
    "client"
  ],
  "author": "Tech for Tomorrow",
  "license": "MIT",
  "devDependencies": {
    "@types/chai": "^4.3.20",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.5",
    "tsup": "^8.0.2",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.9"
  }
}
