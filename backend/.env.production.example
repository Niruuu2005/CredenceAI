# Production environment template — copy to .env and fill in real values.
# Used by: docker compose -f docker-compose.prod.yml --env-file .env up --build

APP_ENV=production
MOCK_SERVICES=false
CELERY_ALWAYS_EAGER=false
RATE_LIMIT_ENABLED=true
ENABLE_API_KEY_AUTH=true

# Database (Postgres — or Neon connection string for Render)
POSTGRES_USER=user
POSTGRES_PASSWORD=
POSTGRES_DB=credenceai
DATABASE_URL=postgresql://user:CHANGE_ME@postgres:5432/credenceai

# Redis (or Upstash rediss:// URL for Render)
# ssl_cert_reqs is auto-appended in code via REDIS_SSL_CERT_REQS (default CERT_REQUIRED).
# Optional explicit URL override: rediss://...?ssl_cert_reqs=CERT_NONE
REDIS_URL=redis://redis:6379/0
REDIS_SSL_CERT_REQS=CERT_REQUIRED
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=

# Google OAuth — redirect URI must match frontend callback exactly
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-app.vercel.app/auth/google/callback

# GitHub OAuth — at least one of Google or GitHub required in production
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://your-app.vercel.app/auth/github/callback

# CORS — JSON list, no trailing slashes
CORS_ALLOWED_ORIGINS=["https://your-app.vercel.app"]

# Frontend Docker build arg (self-hosted compose only)
VITE_API_BASE_URL=https://your-api.onrender.com/api

# MinIO object storage
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# Search infrastructure (internal Docker hostnames for compose; optional when SEARCH_PROVIDER=duckduckgo)
SEARXNG_BASE_URL=http://searxng:8080
SEARCH_PROVIDER=duckduckgo
OPENSEARCH_URL=http://opensearch:9200

# Stripe billing (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_ENTERPRISE=
STRIPE_SUCCESS_URL=https://your-app.vercel.app/app/billing?success=1
STRIPE_CANCEL_URL=https://your-app.vercel.app/app/billing?canceled=1
