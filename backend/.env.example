APP_ENV=local
APP_NAME=credenceai
MOCK_SERVICES=true
CELERY_ALWAYS_EAGER=true
OPENAI_API_KEY=
DATABASE_URL=sqlite:///./credenceai.db
REDIS_URL=redis://localhost:6379/0
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=change-me
MINIO_SECRET_KEY=change-me
OPENSEARCH_URL=http://localhost:9200
LOG_LEVEL=INFO

# Sources
SEARXNG_BASE_URL=http://localhost:8080
ENABLE_WIKIDATA=true
ENABLE_WIKIPEDIA=true
ENABLE_GDELT=true
ENABLE_COMMONCRAWL=true
ENABLE_OPENALEX=true
ENABLE_CROSSREF=false
ENABLE_ARXIV=false
ENABLE_PAID_SERP=false

# Budgets
DEFAULT_MAX_SOURCES=4
DEFAULT_MAX_URLS_TO_CRAWL=20
DEFAULT_DEADLINE_MS=12000

# API Key Auth
ENABLE_API_KEY_AUTH=false
API_KEY_HEADER_NAME=X-API-Key

# CORS (JSON list of allowed frontend origins)
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Auth — Google OAuth (production)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Auth — GitHub OAuth (production; at least one OAuth provider required)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# Database pool (PostgreSQL production)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=1800

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_ENTERPRISE=
STRIPE_SUCCESS_URL=http://localhost:3000/app/billing?success=1
STRIPE_CANCEL_URL=http://localhost:3000/app/billing?canceled=1

# Auth — local developer login only (APP_ENV=local)
DEV_LOGIN_USERNAME=
DEV_LOGIN_PASSWORD=

# Rate Limiting
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=60

# API Version (returned in /health)
API_VERSION=0.1.0
