# Local dev: point at the backend directly.
VITE_API_BASE_URL=http://localhost:8000/api

# Vercel production: same-origin proxy (recommended)
# VITE_API_BASE_URL=https://credence-ai-gamma.vercel.app/api
#
# vercel.json rewrites /api/* → https://credenceai-api.onrender.com/api/*
# Do NOT set VITE_API_BASE_URL to the Render URL — that causes CORS errors.
